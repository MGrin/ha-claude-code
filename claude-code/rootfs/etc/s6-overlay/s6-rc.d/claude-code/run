#!/command/with-contenv bash
# shellcheck shell=bash

export HOME=/data
export LANG=C.UTF-8
export LC_ALL=C.UTF-8

# ── Create persistent workspace ──────────────────────────
mkdir -p /data/workspace
mkdir -p /data/.claude

# ── Write CLAUDE.md for HA context ───────────────────────
cat > /data/workspace/CLAUDE.md << 'CLAUDEMD'
# Home Assistant Claude Code

You are running inside a Home Assistant add-on container on a Raspberry Pi.

## Home Assistant API Access

You have an MCP server called `home-assistant` with tools to interact with HA:

- `ha_get_states` — Get all entity states (optionally filter by domain)
- `ha_get_state` — Get state of a specific entity
- `ha_call_service` — Call any HA service. ALWAYS use entity_id, not area_id.
- `ha_get_services` — List available services
- `ha_create_automation` — Create automations
- `ha_get_config` — Get HA configuration
- `ha_fire_event` — Fire events
- `ha_addon_info` — Get add-on information
- `ha_supervisor_info` — Get system information

## For Dashboard Modifications

Use a Python script with websockets:
```python
import asyncio, json, os, websockets
async def main():
    token = os.environ['SUPERVISOR_TOKEN']
    async with websockets.connect('ws://supervisor/core/websocket') as ws:
        await ws.recv()
        await ws.send(json.dumps({'type': 'auth', 'access_token': token}))
        await ws.recv()
        # send commands...
```

## Environment
- Working directory: /data/workspace (persistent, backed up)
- HA config: /config (read-only)
- Platform: Raspberry Pi (aarch64), HA OS
- SUPERVISOR_TOKEN in environment
CLAUDEMD

# ── Write MCP config for HA tools ────────────────────────
cat > /data/workspace/.mcp.json << MCPJSON
{
  "mcpServers": {
    "home-assistant": {
      "command": "/root/.bun/bin/bun",
      "args": ["run", "/app/src/ha-mcp.ts"],
      "env": {
        "SUPERVISOR_TOKEN": "${SUPERVISOR_TOKEN}"
      }
    }
  }
}
MCPJSON

# ── Apply credentials from add-on options ────────────────
if [ -f /data/options.json ]; then
    CREDS_JSON=$(jq -r '.credentials_json // ""' /data/options.json)
    if [ -n "$CREDS_JSON" ] && [ "$CREDS_JSON" != "" ] && [ "$CREDS_JSON" != "null" ]; then
        echo "$CREDS_JSON" > /data/.claude/.credentials.json
        echo "Credentials applied from add-on options."
    fi
fi

# ── Start ttyd directly on Ingress port ──────────────────
echo "Starting Claude Code terminal on port 5100..."
exec ttyd \
    --port 5100 \
    --writable \
    --client-option reconnect=5 \
    --client-option fontSize=14 \
    /usr/local/bin/claude-launcher.sh
